# Allow documentation README files inside data
!data/README.md
!data/sample/
!data/sample/README.md

# If synthetic examples are added later, allow only explicitly named sample files
!data/sample/synthetic_*.csv
!data/sample/example_*.csv
!data/sample/*.json

